# === Smart Notepad — Production Environment Variables ===
# Copy this file to .env and fill in real values before deploying.

# PostgreSQL
POSTGRES_USER=notepad
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=smart_notepad

# JWT secrets — must be long random strings in production
JWT_ACCESS_SECRET=CHANGE_THIS_ACCESS_SECRET_64CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_64CHARS_MIN
