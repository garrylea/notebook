generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String?   @unique
  password_hash String
  avatar_url    String?
  preferences   String?   // JSON stored as string in SQLite
  status        Int       @default(1)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  is_deleted    Int       @default(0)

  notes         Note[]
  activityLogs  ActivityLog[]

  @@map("sys_user")
}

model Note {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  title        String
  content      String?
  color        String    @default("blue")
  status       String    @default("draft")
  priority     String    @default("medium")
  tags         String?   // JSON array stored as string
  due_date     DateTime?
  pin_top      Int       @default(0)
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  is_deleted   Int       @default(0)

  user         User          @relation(fields: [userId], references: [id])
  subtasks     Subtask[]
  attachments  Attachment[]
  activityLogs ActivityLog[]

  @@index([userId, is_deleted, created_at], map: "idx_user_created")
  @@index([userId, is_deleted, due_date], map: "idx_user_due")
  @@index([userId, status, is_deleted], map: "idx_user_status")
  @@map("busi_note")
}

model Subtask {
  id           String    @id @default(uuid())
  noteId       String    @map("note_id")
  parent_id    String?
  title        String
  status       String    @default("pending")
  is_completed Boolean   @default(false)
  sort_order   Int       @default(0)
  due_date     DateTime?
  assignee     String?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  note         Note      @relation(fields: [noteId], references: [id])
  parent       Subtask?  @relation("SubtaskToSubtask", fields: [parent_id], references: [id])
  children     Subtask[] @relation("SubtaskToSubtask")

  @@index([noteId])
  @@index([parent_id])
  @@map("busi_subtask")
}

model Attachment {
  id         String    @id @default(uuid())
  noteId     String    @map("note_id")
  file_name  String
  file_size  Int       // bytes, Int sufficient for < 2GB
  file_type  String
  file_path  String
  md5_hash   String?
  created_at DateTime  @default(now())
  is_deleted Int       @default(0)

  note       Note      @relation(fields: [noteId], references: [id])

  @@index([noteId])
  @@index([md5_hash])
  @@map("busi_attachment")
}

model ActivityLog {
  id          String    @id @default(uuid())
  noteId      String    @map("note_id")
  userId      String    @map("user_id")
  action_type String
  detail      String?   // JSON stored as string
  created_at  DateTime  @default(now())

  note        Note      @relation(fields: [noteId], references: [id])
  operator    User      @relation(fields: [userId], references: [id])

  @@index([noteId])
  @@index([created_at])
  @@map("sys_activity_log")
}
